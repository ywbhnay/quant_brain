# PostgreSQL 连接
# 默认指向 quant_data_pipeline 已填充的 ETL 库
PG_HOST=192.168.3.11
PG_PORT=5432
PG_USER=quant_user
PG_PASSWORD=
PG_DATABASE=quant_db

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Tushare API Token
# 仅 RealtimeQuoteClient (实时 5 档快照) 需要；纯 PG 读取模式可留空
TUSHARE_TOKEN=

# Web 后端
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=2

# 跑批配置
BATCH_CHUNK_SIZE=100
BATCH_MAX_MEMORY_MB=1500
